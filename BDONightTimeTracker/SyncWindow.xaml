<Window x:Class="BDONightTimeTracker.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="280"
        Height="180"
        ShowInTaskbar="False"
        Title="Sync BDO Time">

    <Window.Resources>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#445588CC"/>
            <Setter Property="Foreground"       Value="#DDEEFF"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5566AADD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#336699BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="#22FFFFFF"/>
            <Setter Property="Foreground"       Value="#778899"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeInputStyle" TargetType="TextBox">
            <Setter Property="Background"       Value="#33FFFFFF"/>
            <Setter Property="Foreground"       Value="#DDEEFF"/>
            <Setter Property="BorderBrush"      Value="#3355AACC"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CaretBrush"       Value="#DDEEFF"/>
            <Setter Property="SelectionBrush"   Value="#5566AADD"/>
            <Setter Property="FontSize"         Value="24"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="TextAlignment"    Value="Center"/>
            <Setter Property="MaxLength"        Value="2"/>
            <Setter Property="Width"            Value="58"/>
            <Setter Property="Padding"          Value="4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6688BBDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="#EE0D0D1A"
            CornerRadius="12"
            BorderBrush="#3355AACC"
            BorderThickness="1"
            MouseLeftButtonDown="MainBorder_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="4" Opacity="0.7"/>
        </Border.Effect>

        <Grid Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Sync BDO Time"
                       FontSize="13" FontWeight="Bold"
                       Foreground="#99AABB"/>

            <TextBlock Grid.Row="2"
                       Text="Enter the current in-game time:"
                       FontSize="11" Foreground="#556677"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox x:Name="HourBox"
                         Style="{StaticResource TimeInputStyle}"
                         Text="12"
                         PreviewTextInput="TimeBox_PreviewTextInput"
                         GotFocus="TimeBox_GotFocus"/>
                <TextBlock Text=":"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#334455"
                           VerticalAlignment="Center"
                           Margin="6,0"/>
                <TextBox x:Name="MinuteBox"
                         Style="{StaticResource TimeInputStyle}"
                         Text="00"
                         PreviewTextInput="TimeBox_PreviewTextInput"
                         GotFocus="TimeBox_GotFocus"/>
            </StackPanel>

            <TextBlock x:Name="ErrorLabel"
                       Grid.Row="4"
                       Text="Invalid time (e.g. 14:30)"
                       FontSize="10" Foreground="#FF6677"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"
                       Margin="0,44,0,0"
                       Visibility="Collapsed"/>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Confirm"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ConfirmButton_Click"/>

                <Button Grid.Column="2" Content="Cancel"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
