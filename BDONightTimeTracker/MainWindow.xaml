<Window x:Class="BDONightTimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Width="195"
        Height="40"
        Left="100"
        Top="100"
        Title="BDO Night Tracker">

    <Window.Resources>

        <Style x:Key="FlatButtonBase" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="20"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatInfoButtonStyle" TargetType="Button"
               BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Foreground" Value="#334455"/>
            <Setter Property="FontSize"   Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33446655"/>
                    <Setter Property="Foreground" Value="#7799BB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatCloseButtonStyle" TargetType="Button"
               BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Foreground" Value="#556677"/>
            <Setter Property="FontSize"   Value="9"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#55FF4455"/>
                    <Setter Property="Foreground" Value="#FF6677"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#88FF2233"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlatOcrButtonStyle" TargetType="Button"
               BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Foreground" Value="#334455"/>
            <Setter Property="FontSize"   Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3355AACC"/>
                    <Setter Property="Foreground" Value="#88CCEE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#5566AACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border x:Name="MainBorder"
            Background="#CC0D0D1A"
            CornerRadius="10"
            BorderBrush="#3355AACC"
            BorderThickness="1"
            MouseLeftButtonDown="MainBorder_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Opacity="0.7"/>
        </Border.Effect>

        <Grid Margin="10,0,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- phase icon -->
                <ColumnDefinition Width="*"/>      <!-- countdown -->
                <ColumnDefinition Width="Auto"/>  <!-- ↺ -->
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="Auto"/>  <!-- ℹ -->
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="Auto"/>  <!-- ✕ -->
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="PhaseIconText"
                       Grid.Column="0"
                       Text="⏳"
                       FontSize="20"
                       FontFamily="Segoe UI Symbol"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="NextTransitionLabel"
                       Grid.Column="1"
                       Text=""
                       FontSize="12"
                       Foreground="#8899BB"
                       VerticalAlignment="Center"
                       Margin="8,0,4,0"/>

            <Button Grid.Column="2"
                    Content="↺"
                    VerticalAlignment="Center"
                    Style="{StaticResource FlatOcrButtonStyle}"
                    Click="ForceOcrButton_Click">
                <Button.ToolTip>
                    <ToolTip Content="Force OCR sync"
                             Background="#1A1A2E" Foreground="#AABBCC"
                             BorderBrush="#3355AACC"/>
                </Button.ToolTip>
            </Button>

            <!-- Credits -->
            <Button Grid.Column="4"
                    Content="ℹ"
                    VerticalAlignment="Center"
                    Style="{StaticResource FlatInfoButtonStyle}">
                <Button.ToolTip>
                    <ToolTip Background="#1A1A2E" BorderBrush="#3355AACC" Foreground="#AABBCC"
                             FontSize="11" Padding="8,5">
                        <StackPanel>
                            <TextBlock Text="Created by"/>
                            <TextBlock Text="Family Name: SilverBolts" FontWeight="Bold" Foreground="#DDEEFF"/>
                            <TextBlock Text="Server: EU"/>
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
            </Button>

            <Button Grid.Column="6"
                    Content="✕"
                    VerticalAlignment="Center"
                    Style="{StaticResource FlatCloseButtonStyle}"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>
